<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pizza Order Form</title>
  </head>

  <body>
      <main>
        <form>
          <h2>PERSONAL DETAILS</h2>
          <label for="fullname">Full Name:</label><br />
          <input
            type="text"
            id="fullname"
            name="fullname"
            required
            minlength="5"
            maxlength="60"
          /><br /><br />

          <label for="email">Email:</label><br />
          <input type="email" id="email" name="email" required /><br /><br />

          <label for="phone">Phone Number:</label><br />
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            pattern="[0-9]{7,11}"
          /><br /><br />

          <label for="age">Age:</label><br />
          <input
            type="number"
            id="age"
            name="age"
            required
            min="13"
            max="99"
          /><br /><br />

          <h2>PIZZA SIZE</h2>
          <input type="radio" id="small" name="pizza_size" value="small" />
          <label for="small">Small</label><br />
          <input
            type="radio"
            id="medium"
            name="pizza_size"
            value="medium"
            checked
          />
          <label for="medium">Medium</label><br />
          <input type="radio" id="large" name="pizza_size" value="large" />
          <label for="large">Large</label><br />
          <input
            type="radio"
            id="extralarge"
            name="pizza_size"
            value="extralarge"
          />
          <label for="extralarge">Extra Large</label><br /><br />

          <h2>CRUST TYPE</h2>
          <select id="crust" name="crust" required>
            <option value="" disabled selected>-- Choose a crust --</option>
            <option value="thin">Thin</option>
            <option value="thick">Thick</option>
            <option value="stuffed">Stuffed</option>
            <option value="gluten-free">Gluten-Free</option></select
          ><br /><br />

          <h2>PIZZA SAUCE</h2>
          <select id="sauce" name="sauce" required>
            <optgroup label="Classic">
              <option value="tomato">Tomato</option>
              <option value="garlic-white">Garlic White</option>
            </optgroup>
            <optgroup label="Special">
              <option value="pesto">Pesto</option>
              <option value="barbecue">Barbecue</option>
            </optgroup></select
          ><br /><br />

          <h2>PIZZA TOPPINGS</h2>

          <input type="checkbox" id="cheese" name="topping" value="cheese" checked disabled>
          <label for="cheese">Cheese (Always Included)</label><br><br>

          <input type="checkbox" id="pepperoni" name="topping" value="pepperoni">
          <label for="pepperoni">Pepperoni</label><br><br>

          <input type="checkbox" id="mushrooms" name="topping" value="mushrooms">
          <label for="mushrooms">Mushrooms</label><br><br>

          <input type="checkbox" id="onions" name="topping" value="onions">
          <label for="onions">Onions</label><br><br>

          <input type="checkbox" id="bellpepper" name="topping" value="bellpepper">
          <label for="bellpepper">Bell Pepper</label><br><br>

          <input type="checkbox" id="olives" name="topping" value="olives">
          <label for="olives">Olives</label><br><br>

          <input type="checkbox" id="bacon" name="topping" value="bacon">
          <label for="bacon">Bacon</label><br><br>

          <input type="checkbox" id="pineapple" name="topping" value="pineapple" title="Warning: Pineapple on pizza is controversial!">
          <label for="pineapple">Pineapple</label><br><br>

          <h2>DELIVERY METHOD</h2>
        
          <input type="radio" id="delivery" name="deliverymethod" value="homedelivery">
          <label for="delivery">Home Delivery</label><br><br>
        
          <input type="radio" id="pickup" name="deliverymethod" value="storepick-up">
          <label for="pickup">Store Pick-up</label>

          <br>

          <label for="address">Delivery Address:</label><br>
          <textarea id="address" name="address" rows="4" placeholder="Enter your delivery address here..."></textarea>

          <br><br>

          <h2>PAYMENT INFORMATION</h2>

          <fieldset>
            <legend>Payment Details</legend>

            <label for="paymentmethod">Payment Method:</label><br>
            <select id="paymentmethod" name="paymentmethod" required>
              <option value="">--Select Payment Method--</option>
              <option value="creditcard">Credit Card</option>
              <option value="gcash">GCash</option>
              <option value="cashondelivery">Cash on Delivery</option>
            </select>

            <br><br>

            <label for="cardnumber">
              Card Number (Required for Credit Card only):
            </label><br>
            <input
              type="text"
              id="cardnumber"
              name="cardnumber"
              pattern="[0-9]{16}"
              placeholder="1234567890123456"
              title="Please enter exactly 16 digits (numbers only, no spaces)">
          </fieldset>

          <br><br>

          <h2>ORDER SUMMARY</h2>

          <table border="1" cellpadding="8">
            <thead>
              <tr>
                <th>Size</th>
                <th>Base Price</th>
                <th>Extra Toppings (each)</th>
              </tr>
            </thead>

            <tbody>
              <tr>
                <td>Small</td>
                <td>₱199</td>
                <td>+₱20</td>
              </tr>
              <tr>
                <td>Medium</td>
                <td>₱299</td>
                <td>+₱25</td>
              </tr>
              <tr>
                <td>Large</td>
                <td>₱399</td>
                <td>+₱30</td>
              </tr>
              <tr>
                <td>Extra Large</td>
                <td>₱499</td>
                <td>+₱35</td>
              </tr>
            </tbody>
          </table>

          <br><br>

          <button type="submit">Place My Order</button>
          <button type="reset">Start Over</button>
        </form>
      </main>
    </div>

  </body>
</html>
